# === FarmTown Sentinel bot config ===

# Solana wallet — pakai WALLET KHUSUS/BURNER, jangan wallet utama.
# Base58 secret key (format Phantom export) ATAU JSON array 64-byte. (WAJIB)
SOLANA_SECRET_KEY=

# Origin & realtime host (jangan diubah kecuali staging)
API_ORIGIN=https://play.farmtown.online
REALTIME_URL=https://realtime.farmtown.online

# Supabase project (auth). anon key dipakai untuk refresh token tanpa captcha.
SUPABASE_URL=https://irarxwyrpmmxacrbvpnz.supabase.co
SUPABASE_ANON_KEY=

# Identitas in-game
DISPLAY_NAME=ohmaygawd
ROOM_ID=farmtown-dev

# Telegram kontrol (opsional tapi disarankan). Tanpa token, telegram nonaktif.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Jam aktif bot (anti-ban: bot "tidur" di luar jam ini). Format HH:MM-HH:MM atau "24h".
ACTIVE_HOURS=06:00-23:30

# --- legacy (tidak dipakai lagi; auth sekarang via Supabase+wallet) ---
# FARMTOWN_COOKIE=
# FARMTOWN_BEARER=

# Solana RPC for /wallet balance + withdraw (public default is rate-limited; use your own)
SOLANA_RPC=https://api.mainnet-beta.solana.com
# Your MAIN wallet to withdraw earned $FARM to (leave empty to disable withdraw)
WITHDRAW_ADDRESS=

# --- Multi-account (experimental) ---
# Main wallet (SOLANA_SECRET_KEY) + up to 49 generated sub-wallets = 50 farms, all under
# ONE pasted Supabase session. Generate subs from Telegram: /genwallets <n>. Fund each sub
# with a little SOL for gas; sub $FARM is auto-swept to the main wallet (/sweep to force).
# Concurrent sub-FARMING engine is gated by this flag (default off — verify on a healthy
# server with 1-2 subs first). Monitoring (/accounts) + sweep work regardless.
MULTI_ACCOUNT=off
