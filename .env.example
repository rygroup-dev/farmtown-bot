# === FarmTown Sentinel bot config ===

# Solana wallet — pakai WALLET KHUSUS/BURNER, jangan wallet utama.
# Base58 secret key (format Phantom export) ATAU JSON array 64-byte. (WAJIB)
SOLANA_SECRET_KEY=

# Origin & realtime host (jangan diubah kecuali staging)
API_ORIGIN=https://play.farmtown.online
REALTIME_URL=https://realtime.farmtown.online

# Supabase project (auth). anon key dipakai untuk refresh token tanpa captcha.
SUPABASE_URL=https://irarxwyrpmmxacrbvpnz.supabase.co
SUPABASE_ANON_KEY=

# Identitas in-game
DISPLAY_NAME=ohmaygawd
ROOM_ID=farmtown-dev

# Telegram kontrol (opsional tapi disarankan). Tanpa token, telegram nonaktif.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Jam aktif bot (anti-ban: bot "tidur" di luar jam ini). Format HH:MM-HH:MM atau "24h".
ACTIVE_HOURS=06:00-23:30

# --- legacy (tidak dipakai lagi; auth sekarang via Supabase+wallet) ---
# FARMTOWN_COOKIE=
# FARMTOWN_BEARER=

# Solana RPC for /wallet balance + withdraw (public default is rate-limited; use your own)
SOLANA_RPC=https://api.mainnet-beta.solana.com
# Your MAIN wallet to withdraw earned $FARM to (leave empty to disable withdraw)
WITHDRAW_ADDRESS=

# --- Multi-account (experimental) ---
# Main wallet (SOLANA_SECRET_KEY) + up to 49 generated sub-wallets = 50 concurrent farms.
# Each account runs its OWN Supabase session (a server limit: one session authorizes only
# one wallet at a time). With CAPTCHA_API_KEY set, each sub AUTO-MINTS its session — you
# only fund each sub a little SOL for gas; sub $FARM auto-sweeps to the main wallet.
# Setup: /genwallets <n> → fund each sub's SOL → MULTI_ACCOUNT=on → restart. /accounts to watch.
# Gated off by default; verify with 1-2 subs first. Monitoring (/accounts) + /sweep work regardless.
MULTI_ACCOUNT=off
# Stage the rollout: cap how many sub-farms actually run (0 = all generated). Start small
# (e.g. 5), verify, then raise. NOTE: many accounts from one IP raises ban risk.
MULTI_ACCOUNT_LIMIT=0

# Captcha solver (optional) — lets each sub-account AUTO-MINT its Supabase session (no
# browser paste). Without it, every sub needs its own pasted session. Any 2Captcha/
# Anti-Captcha/CapMonster-compatible key works; you supply + fund it (~$0.001-0.003/solve).
# Test from Telegram with /mintsession before enabling MULTI_ACCOUNT.
CAPTCHA_API_KEY=
# CAPTCHA_ENDPOINT=https://api.2captcha.com   # override for anti-captcha / capmonster hosts

# Farmer Pool — level SACRIFICE strategy (advanced). At max level (30) all further XP is
# wasted, so optionally burn levels into the pool for $FARM claim power (3 power/level),
# then re-grind. Never burns below POOL_LEVEL_FLOOR; only sacrifices once at POOL_SACRIFICE_AT.
POOL_BURN_LEVELS=off
POOL_LEVEL_FLOOR=13
POOL_SACRIFICE_AT=30
