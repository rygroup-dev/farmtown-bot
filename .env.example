# === FarmTown bot config ===
# WAJIB: cookie dari sesi login asli di browser (Application > Cookies, copy semua jadi 1 string "k=v; k2=v2")
FARMTOWN_COOKIE=

# Token yang dipakai header Authorization untuk REST /api/* (Supabase accessToken / walletSessionToken)
# (recon akan coba ambil otomatis dari /api/auth/session pakai cookie di atas)
FARMTOWN_BEARER=

# Solana wallet — pakai WALLET KHUSUS/BURNER, jangan wallet utama.
# Base58 secret key (format Phantom export) ATAU JSON array 64-byte.
SOLANA_SECRET_KEY=

# Origin & realtime host (jangan diubah kecuali staging)
API_ORIGIN=https://play.farmtown.online
REALTIME_URL=https://realtime.farmtown.online
